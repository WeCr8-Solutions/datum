# ============================================================
# DATUM — Environment Configuration
# FORGE · ANVIL · PANEL
#
# Copy to .env and fill in your values.
# This single file configures all three systems.
# ============================================================

# ── DEPLOYMENT MODE ───────────────────────────────────────
# "cloud"   → Supabase + OpenAI/Anthropic (standard shops)
# "onprem"  → Ollama + Chroma + local server (ITAR shops)
DEPLOYMENT_MODE=cloud

# ── CLIENT IDENTITY ───────────────────────────────────────
CLIENT_NAME="Acme Machine Co"
CLIENT_ID="acme-machine-co"
CLIENT_TIER=starter

# ── AI — LOCAL (Ollama, always primary) ───────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── AI — CLOUD FALLBACK (optional) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── VECTOR DB — CLOUD (Supabase) ──────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ── VECTOR DB — ON-PREM (Chroma) ──────────────────────────
CHROMA_URL=http://localhost:8000

# ── RAG BACKEND ───────────────────────────────────────────
WECR8_API_BASE=http://localhost:3001/api
WECR8_ADMIN_JWT=eyJ...
WECR8_CLIENT_ID=acme-machine-co

# ── AUTH ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
ADMIN_EMAIL=admin@yourshop.com
ADMIN_PASSWORD_HASH=

# ── FORGE ─────────────────────────────────────────────────
FORGE_PATH=./forge
FORGE_LOG_LEVEL=INFO

# ── ANVIL ─────────────────────────────────────────────────
ANVIL_PATH=./anvil

# ── PANEL ─────────────────────────────────────────────────
PANEL_PORT=4000
PANEL_BASE_URL=http://localhost:4000
PANEL_REVIEWER_NAME=Zach
PANEL_REVIEWER_EMAIL=zach@wecr8.info

# ── EMAIL NOTIFICATIONS ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=panel@wecr8.info
